# Copy to .env.local and fill in. .env.local is git-ignored.

# Required for the TanStack AI chat assistant (Anthropic Claude).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Your deployed Netlify site URL. Used by Netlify Identity in the browser.
# Locally this can be left blank.
VITE_NETLIFY_SITE_URL=

# NETLIFY_DATABASE_URL is NOT set here — it is provisioned automatically:
#   - locally: by `netlify dev` (a real local Postgres is started for you)
#   - production: by `netlify db init` (serverless Neon Postgres)
